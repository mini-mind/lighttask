{
  "compilerOptions": {
    "target": "ES2023",
    "module": "Node20",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*"
  ]
}
